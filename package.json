{
  "name": "pcc-foundation-react-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx vite",
    "build": "bunx tsc -b && bun x vite build",
    "lint": "bunx eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "bunx prettier --write \"src/**/*.{js,jsx,ts,tsx,css,scss}\"",
    "fallow": "bunx fallow",
    "preview": "bunx vite preview",
    "tsc": "bunx tsc --noEmit",
    "allow-scripts": "allow-scripts auto"
  },
  "license": "PROPRIETARY",
  "dependencies": {
    "framer-motion": "^12.42.2",
    "immer": "11.1.10",
    "lenis": "^1.3.25",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "10.0.1",
    "@lavamoat/allow-scripts": "5.1.0",
    "@rolldown/plugin-babel": "0.2.3",
    "@tailwindcss/vite": "4.3.1",
    "@types/babel__core": "7.20.5",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "fallow": "2.98.0",
    "globals": "17.7.0",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.1",
    "vite-tsconfig-paths": "6.1.1"
  },
  "trustedDependencies": [
    "vite",
    "@vitejs/plugin-react",
    "eslint",
    "tailwindcss",
    "esbuild",
    "unrs-resolver",
    "@firebase/util",
    "core-js",
    "protobufjs"
  ],
  "lavamoat": {
    "allowScripts": {
      "esbuild": true,
      "protobufjs": true,
      "core-js": true,
      "unrs-resolver": true,
      "$root$": false
    }
  }
}
